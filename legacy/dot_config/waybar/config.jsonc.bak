{
	// "layer": "top",
	"position": "top",
	"spacing": 5,
	"margin": "0 0 5",
	"reload_style_on_change": true,
	"fixed-center": true,
	"modules-left": [
		"custom/arch",
		"hyprland/workspaces",
		"group/keyboards",
		"cava"
	],
	"modules-center": ["hyprland/window"],
	"modules-right": [
		"idle_inhibitor",
		"privacy",
		"group/connections",
		"cava",
		"pulseaudio",
		"backlight",
		"group/usage",
		"battery",
		"clock",
		"tray",
		"group/powers"
	],

	// Left Modules
	"custom/arch": {
		"format": "¾░Żć ",
		"on-click": "pkill wofi || wofi --show drun -I",
		"tooltip": true,
		"tooltip-format": "btw"
	},
	"hyprland/workspaces": {
		"show-special": true,
		"format": "{icon}",
		"format-icons": {
			"1": "’äĀ ",
			"2": "’ē® ",
			"3": "’äĪ ",
			"4": "¾░ŖŚ ",
			"5": "’üĄ ",
			"urgent": "’ü¬ ",
			"active": "’åÆ ",
			"default": "’äæ "
		},
		"persistent-workspaces": {
			"*": 5
		}
	},
	"group/keyboards": {
		"orientation": "horizontal",
		"modules": ["hyprland/language", "keyboard-state"],
		"drawer": {
			"transition-duration": 500,
			"children-class": "not-keyboards",
			"transition-left-to-right": true
		}
	},
	"hyprland/language": {
		"format": "\uf1ab {short}"
	},
	"keyboard-state": {
		"numlock": true,
		"capslock": true,
		"format": "{name} {icon}",
		"format-icons": {
			"locked": "’ĆŻ ",
			"unlocked": "’é£ "
		}
	},
	"cava": {
		"cava_config": "$XDG_CONFIG_HOME/cava/config",
		"framerate": 30,
		"autosens": 1,
		"bars": 14,
		"lower_cutoff_freq": 50,
		"higher_cutoff_freq": 10000,
		"method": "pulseaudio",
		"source": "auto",
		"stereo": true,
		"bar_delimiter": 0,
		"noise_reduction": 0.77,
		"input_delay": 2,
		"hide_on_silence": true,
		"format-icons": ["Ō¢ü", "Ō¢é", "Ō¢ā", "Ō¢ä", "Ō¢ģ", "Ō¢å", "Ō¢ć", "Ō¢ł"],
		"actions": {
			"on-click-right": "mode"
		}
	},
	// Center Modules
	"hyprland/window": {
		"icon": true,
		"icon-size": 16
	},
	// Right Modules
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "’ü« ",
			"deactivated": "’ü░ "
		}
	},
	"privacy": {
		"icon-spacing": 4,
		"icon-size": 18,
		"transition-duration": 250,
		"modules": [
			{
				"type": "screenshare",
				"tooltip": true,
				"tooltip-icon-size": 24
			},
			{
				"type": "audio-out",
				"tooltip": true,
				"tooltip-icon-size": 24
			},
			{
				"type": "audio-in",
				"tooltip": true,
				"tooltip-icon-size": 24
			}
		]
	},
	"group/connections": {
		"orientation": "horizontal",
		"modules": ["network", "bluetooth"]
	},
	"network": {
		"on-click": "kitty --name Networks --detach -1 nmtui",
		"format": "{ifname}",
		"format-wifi": "’ć½ ",
		"format-ethernet": "’āü ",
		"format-disconnected": "ŌÜĀ ",
		"tooltip-format-disconnected": "Disconnected"
	},
	"bluetooth": {
		"format": "\udb80\udcaf",
		"format-disabled": "\udb80\udcb2",
		"format-connected": "\udb80\udcb1",
		"tooltip-format": "{controller_alias}\t{controller_address}",
		"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}"
	},
	"pulseaudio": {
		"format": "{icon} {volume}%",
		"rotate": 0,
		"format-muted": "{icon}",
		"on-click": "pavucontrol -t 3",
		"on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
		"on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
		"on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
		"tooltip-format": "{icon} {desc} {volume}%",
		"ignored-sinks": ["Easy Effects Sink"],
		"scroll-step": 5,
		"format-icons": {
			"headphone": "’Ćź ",
			"hands-free": "’Ćź ",
			"headset": "’Ćź ",
			"phone": "’éĢ ",
			"portable": "’éĢ ",
			"car": "’å╣ ",
			"default": ["’Ć” ", "’Ć¦ ", "’Ć© "]
		}
	},
	"backlight": {
		"device": "intel_backlight",
		"format": "{icon} {percent}%",
		"format-icons": ["’åģ ", "’äæ "]
		// "on-scroll-up": "brightnessctl -d $backlight set 5%+",
		// "on-scroll-down": "brightnessctl -d $backlight set 5%-",
		// "scroll-step": 0.5
	},
	"group/usage": {
		"orientation": "horizontal",
		"modules": ["temperature", "cpu", "memory"],
		"drawer": {
			"transition-duration": 500,
			"children-class": "not-usage",
			"transition-left-to-right": false
		}
	},
	"temperature": {
		"format": "’ŗē {temperatureC}┬░C"
	},
	"cpu": {
		"interval": 10,
		"format": "\uf4bc {}%",
		"max-length": 10
	},
	"memory": {
		"interval": 30,
		"format": "\uefc5 {used:0.1f}G"
	},
	"battery": {
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "{icon} {capacity}%",
		"format-charging": "¾░éä {capacity}%",
		"format-icons": [
			"\uf244",
			"\uf243",
			"\uf242",
			"\uf241",
			"\uf240"
		]
	},
	"battery#bat2": {
		"bat": "BAT2"
	},
	"clock": {
		"timezone": "Asia/Jakarta",
		"format": "{:%H:%M}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
		"format-alt": "{:%d-%m-%Y}"
	},
	"tray": {
		"icon-size": 16,
		"spacing": 8
	},
	"group/powers": {
		"orientation": "inherit",
		"drawer": {
			"transition-duration": 500,
			"children-class": "not-power",
			"transition-left-to-right": false
		},
		"modules": [
			"custom/power",
			"custom/quit",
			"custom/lock",
			"custom/reboot"
		]
	},
	"custom/quit": {
		"format": "¾░Ś╝ ",
		"tooltip": false,
		"on-click": "hyprctl dispatch exit"
	},
	"custom/lock": {
		"format": "¾░Źü ",
		"tooltip": false,
		"on-click": "swaylock"
	},
	"custom/reboot": {
		"format": "¾░£ē ",
		"tooltip": false,
		"on-click": "reboot"
	},
	"custom/power": {
		"format": "’Ćæ ",
		"tooltip": false,
		"on-click": "shutdown now"
	}
}

